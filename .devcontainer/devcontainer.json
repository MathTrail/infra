{
    "name": "MathTrail Infrastructure DevContainer",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "updateContentCommand": "sudo chmod 666 /var/run/docker.sock",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {},
        "ghcr.io/devcontainers/features/kubectl-helm-minikube:1.2.2": {},
        "ghcr.io/dapr/cli/dapr-cli:0": {},
        "ghcr.io/eitsupi/devcontainer-features/just:0": {}
    },
    "runArgs": [
        "--cap-add=SYS_PTRACE",
        "--security-opt",
        "seccomp=unconfined",
        "--network=host"
    ],
    "mounts": [
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ],
    "remoteEnv": {
        "MINIKUBE_HOME": "${containerWorkspaceFolder}/.minikube"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-azuretools.vscode-docker",
                "ms-kubernetes-tools.vscode-kubernetes-tools",
                "ms-kubernetes.helm",
                "redhat.vscode-yaml",
                "eamodio.gitlens",
				"sclu1034.justfile",
				"vscode-icons-team.vscode-icons",
				"waderyan.gitblame",
				"donjayamanne.githistory",
				"Tim-Koehler.helm-intellisense"
            ]
        }
    }
}
